# Скопіюй цей файл у .env та підстав свої значення з Supabase Dashboard
# (Project Settings → API → Project URL + anon/publishable key)
#
# ⚠️ ВАЖЛИВО: використовуй ANON / PUBLISHABLE ключ, а НЕ secret/service_role.
# Anon-ключ безпечно лежить у фронтенді — доступ контролюється через
# Row Level Security policies у самій базі (див. supabase/schema.sql).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Не обов'язково: ключ Google Maps (для сторінки магазинів)
# VITE_GOOGLE_MAPS_API_KEY=
