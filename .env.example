# Скопіюй цей файл у .env та підстав свої значення.
# Всі VITE_* змінні вбудовуються в JS-бандл при білді.
# Ніколи не комить реальний .env — він у .gitignore.

# ── Supabase ────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Не обов'язково: ключ Google Maps (для сторінки магазинів)
# VITE_GOOGLE_MAPS_API_KEY=

# ── Google Analytics 4 ──────────────────────────────────────────────
# Measurement ID: GA4 → Admin → Data Streams → твій стрим
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Tag Manager ──────────────────────────────────────────────
# Якщо використовуєш GTM — встав GTM-XXXXXXX.
# Якщо порожньо, GA4 завантажується напряму через VITE_GA4_MEASUREMENT_ID.
VITE_GTM_ID=GTM-XXXXXXX

# ── Meta (Facebook) Pixel ───────────────────────────────────────────
# Pixel ID з Meta Events Manager
VITE_META_PIXEL_ID=000000000000000

# ── Microsoft Clarity ───────────────────────────────────────────────
# Project ID з clarity.microsoft.com
VITE_CLARITY_PROJECT_ID=xxxxxxxxxx

# ── Google Search Console ───────────────────────────────────────────
# Значення атрибуту content тегу <meta name="google-site-verification">
VITE_GSC_VERIFICATION=
